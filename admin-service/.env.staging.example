# Staging secrets for the `admin` Edge Function.
# Deploy with: ./scripts/deploy-staging.sh
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are automatically injected by
# Supabase at runtime — do NOT set them here.

# Supabase staging project ref (from the dashboard URL)
STAGING_PROJECT_REF=

# Custom auth — generate a DIFFERENT secret than production!
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_TTL_DAYS=30

# Cloudflare R2 (S3-compatible) — can reuse the same account, but use a separate bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=health2u-admin-staging-uploads

# OpenAI (GPT-4o API for document analysis)
OPENAI_API_KEY=
