# Secrets for the `admin` Edge Function.
# Push to Supabase with:
#   supabase secrets set --env-file .env
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are automatically injected by
# Supabase at runtime — do NOT set them here. Everything below must be set.

# Custom auth
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_TTL_DAYS=30

# Cloudflare R2 (S3-compatible)
# account_id is in the Cloudflare dashboard top-right, under R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=health2u-admin-dev-uploads

# OpenAI (GPT-4o API for document analysis)
OPENAI_API_KEY=
